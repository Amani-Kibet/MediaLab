<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <title>MediaLab • Candy Crush PRO</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap");
      body {
        font-family: "Poppins", sans-serif;
        touch-action: manipulation;
      }
      canvas {
        image-rendering: crisp-edges;
        touch-action: none;
        cursor: grab;
        filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.3));
      }
      canvas:active {
        cursor: grabbing;
      }
      .floating-text {
        position: absolute;
        pointer-events: none;
        font-weight: 900;
        font-style: italic;
        z-index: 100;
        animation: floatUp 1s ease-out forwards;
        text-shadow:
          2px 2px 0px #000,
          0 0 20px rgba(255, 255, 255, 0.5);
      }
      @keyframes floatUp {
        0% {
          transform: translateY(0) scale(0.5);
          opacity: 0;
        }
        20% {
          transform: translateY(-20px) scale(1.2);
          opacity: 1;
        }
        100% {
          transform: translateY(-100px) scale(1);
          opacity: 0;
        }
      }
    </style>
  </head>
  <body
    class="bg-gradient-to-br from-indigo-900 via-purple-900 to-pink-900 min-h-screen text-white overflow-hidden select-none"
  >
    <div
      id="game-container"
      class="relative flex flex-col items-center justify-center min-h-screen"
    >
      <div
        id="hud"
        class="w-full max-w-md flex justify-between items-center p-6 mb-2 bg-black/20 backdrop-blur-md rounded-b-3xl"
      >
        <div class="text-center">
          <p class="text-xs opacity-60 uppercase font-bold tracking-widest">
            Target
          </p>
          <p id="target-display" class="text-xl font-bold text-yellow-400">
            2500
          </p>
        </div>
        <div
          class="text-center bg-white/10 px-6 py-2 rounded-2xl border border-white/20"
        >
          <p id="label-type" class="text-xs opacity-60 uppercase font-bold">
            Moves
          </p>
          <p id="value-type" class="text-4xl font-black text-white">20</p>
        </div>
        <div class="text-center">
          <p class="text-xs opacity-60 uppercase font-bold tracking-widest">
            Score
          </p>
          <p id="score-display" class="text-2xl font-bold text-pink-400">0</p>
        </div>
      </div>

      <div class="relative">
        <canvas
          id="game-canvas"
          class="rounded-3xl border-4 border-white/10"
        ></canvas>
        <div id="text-layer" class="absolute inset-0 pointer-events-none"></div>
      </div>

      <div class="mt-8 flex gap-4">
        <button
          onclick="location.reload()"
          class="bg-white/10 hover:bg-white/20 p-4 rounded-full transition-all"
        >
          🔄 Restart
        </button>
        <div
          class="bg-black/40 px-6 py-3 rounded-full border border-white/10 flex items-center gap-2"
        >
          <span class="text-pink-400">🏆</span>
          <span id="level-tag" class="font-bold">Level 1</span>
        </div>
      </div>
    </div>

    <div
      id="overlay"
      class="hidden fixed inset-0 bg-black/90 z-[200] flex items-center justify-center backdrop-blur-xl"
    >
      <div class="text-center p-10">
        <h2
          id="overlay-title"
          class="text-6xl font-black mb-4 italic tracking-tighter"
        >
          SUCCESS!
        </h2>
        <p id="overlay-subtitle" class="text-2xl opacity-80 mb-8">
          You crushed it!
        </p>
        <button
          onclick="startNextLevel()"
          class="bg-gradient-to-r from-pink-500 to-yellow-500 px-12 py-5 rounded-full font-bold text-2xl shadow-2xl hover:scale-110 transition-transform"
        >
          NEXT LEVEL →
        </button>
      </div>
    </div>

    <script>
      const ROWS = 8,
        COLS = 8;
      const CANDIES = ["🍭", "🍬", "🍫", "🧁", "🍪", "🍩"];
      const STRIPE = 10,
        BOMB = 11; // Special ID offsets

      let canvas, ctx, CELL;
      let grid = [],
        score = 0,
        moves = 25,
        level = 1,
        target = 2000;
      let isProcessing = false,
        swipeStart = null;
      let particles = [];

      // --- INIT ---
      function init() {
        canvas = document.getElementById("game-canvas");
        ctx = canvas.getContext("2d");
        resize();
        createGrid();
        requestAnimationFrame(gameLoop);

        canvas.addEventListener("mousedown", startSwipe);
        canvas.addEventListener("mouseup", endSwipe);
        canvas.addEventListener("touchstart", (e) => startSwipe(e.touches[0]));
        canvas.addEventListener("touchend", (e) =>
          endSwipe(e.changedTouches[0]),
        );
        updateHUD();
      }

      function resize() {
        const size = Math.min(window.innerWidth * 0.95, 450);
        canvas.width = canvas.height = size;
        CELL = size / COLS;
      }

      function createGrid() {
        grid = [];
        for (let r = 0; r < ROWS; r++) {
          grid[r] = [];
          for (let c = 0; c < COLS; c++) {
            grid[r][c] = {
              type: Math.floor(Math.random() * 6),
              offset: 0,
              isSpecial: 0,
            };
          }
        }
        if (hasMatches().length > 0) createGrid(); // No matches on start
      }

      // --- MATCH LOGIC ---
      function hasMatches() {
        let matches = [];
        // Horizontal
        for (let r = 0; r < ROWS; r++) {
          for (let c = 0; c < COLS - 2; c++) {
            if (
              grid[r][c].type === grid[r][c + 1].type &&
              grid[r][c].type === grid[r][c + 2].type
            ) {
              matches.push({ r, c }, { r, c: c + 1 }, { r, c: c + 2 });
            }
          }
        }
        // Vertical
        for (let c = 0; c < COLS; c++) {
          for (let r = 0; r < ROWS - 2; r++) {
            if (
              grid[r][c].type === grid[r + 1][c].type &&
              grid[r][c].type === grid[r + 2][c].type
            ) {
              matches.push({ r, c }, { r: r + 1, c }, { r: r + 2, c });
            }
          }
        }
        return matches;
      }

      async function processTurn(r1, c1, r2, c2) {
        isProcessing = true;

        // Swap
        let t = grid[r1][c1];
        grid[r1][c1] = grid[r2][c2];
        grid[r2][c2] = t;

        // Check if one is a COLOR BOMB
        if (
          grid[r1][c1].isSpecial === BOMB ||
          grid[r2][c2].isSpecial === BOMB
        ) {
          handleColorBomb(r1, c1, r2, c2);
          moves--;
        } else {
          let matches = hasMatches();
          if (matches.length > 0) {
            moves--;
            await handleMatches(matches);
          } else {
            // Swap back if no match
            grid[r2][c2] = grid[r1][c1];
            grid[r1][c1] = t;
            shake();
          }
        }

        updateHUD();
        isProcessing = false;
        checkGameOver();

        // Shuffle if stuck
        if (!possibleMovesExist()) shuffle();
      }

      async function handleMatches(matches) {
        let unique = [...new Set(matches.map((m) => `${m.r},${m.c}`))];

        // Create Specials?
        if (unique.length === 4)
          spawnSpecial(matches[0].r, matches[0].c, STRIPE);
        if (unique.length >= 5) spawnSpecial(matches[0].r, matches[0].c, BOMB);

        // Pop effect
        unique.forEach((pos) => {
          let [r, c] = pos.split(",").map(Number);
          if (grid[r][c].isSpecial === STRIPE) triggerStripe(r, c);
          createPop(c * CELL + CELL / 2, r * CELL + CELL / 2);
          grid[r][c].type = -1;
          score += 100;
        });

        if (unique.length > 3)
          showText(unique.length > 4 ? "DIVINE!" : "SWEET!", unique[0]);

        await sleep(300);
        dropCandies();
        await sleep(300);

        let nextMatches = hasMatches();
        if (nextMatches.length > 0) await handleMatches(nextMatches);
      }

      function triggerStripe(r, c) {
        for (let i = 0; i < COLS; i++) {
          grid[r][i].type = -1;
          score += 50;
        }
        for (let i = 0; i < ROWS; i++) {
          grid[i][c].type = -1;
          score += 50;
        }
      }

      function handleColorBomb(r1, c1, r2, c2) {
        let bombPos =
          grid[r1][c1].isSpecial === BOMB ? { r: r1, c: c1 } : { r: r2, c: c2 };
        let otherPos =
          grid[r1][c1].isSpecial === BOMB ? { r: r2, c: c2 } : { r: r1, c: c1 };
        let targetType = grid[otherPos.r][otherPos.c].type;

        grid[bombPos.r][bombPos.c].type = -1;
        for (let r = 0; r < ROWS; r++) {
          for (let c = 0; c < COLS; c++) {
            if (grid[r][c].type === targetType) {
              grid[r][c].type = -1;
              score += 200;
              createPop(c * CELL + CELL / 2, r * CELL + CELL / 2);
            }
          }
        }
        showText("COLOR BLAST!", bombPos);
        dropCandies();
      }

      function dropCandies() {
        for (let c = 0; c < COLS; c++) {
          let empty = 0;
          for (let r = ROWS - 1; r >= 0; r--) {
            if (grid[r][c].type === -1) empty++;
            else if (empty > 0) {
              grid[r + empty][c] = grid[r][c];
              grid[r][c] = { type: -1 };
            }
          }
          for (let r = 0; r < empty; r++) {
            grid[r][c] = {
              type: Math.floor(Math.random() * 6),
              offset: -empty,
              isSpecial: 0,
            };
          }
        }
      }

      // --- HELPERS ---
      function spawnSpecial(r, c, type) {
        grid[r][c].isSpecial = type;
      }

      function possibleMovesExist() {
        // Simplified check: looks for any possible 3-match
        return true; // For demo, we assume moves exist or we'd shuffle
      }

      function shuffle() {
        showText("SHUFFLING!", { r: 4, c: 4 });
        createGrid();
      }

      function showText(msg, pos) {
        const layer = document.getElementById("text-layer");
        const div = document.createElement("div");
        div.className = "floating-text";
        div.style.left = pos.c * CELL + "px";
        div.style.top = pos.r * CELL + "px";
        div.innerText = msg;
        layer.appendChild(div);
        setTimeout(() => div.remove(), 1000);
      }

      function updateHUD() {
        document.getElementById("score-display").innerText = score;
        document.getElementById("value-type").innerText = moves;
        document.getElementById("target-display").innerText = target;
        document.getElementById("level-tag").innerText = "Level " + level;
        if (moves < 5)
          document
            .getElementById("value-type")
            .classList.add("text-red-500", "animate-pulse");
        else
          document
            .getElementById("value-type")
            .classList.remove("text-red-500", "animate-pulse");
      }

      function checkGameOver() {
        if (score >= target) {
          showOverlay("LEVEL COMPLETE", "You're a Candy Pro!");
        } else if (moves <= 0) {
          showOverlay("OUT OF MOVES", "Try again, Sugar.");
        }
      }

      function showOverlay(title, sub) {
        document.getElementById("overlay-title").innerText = title;
        document.getElementById("overlay-subtitle").innerText = sub;
        document.getElementById("overlay").classList.remove("hidden");
      }

      function startNextLevel() {
        level++;
        target += 1500;
        moves = 25;
        score = 0;
        document.getElementById("overlay").classList.add("hidden");
        createGrid();
        updateHUD();
      }

      // --- SWIPE ---
      function startSwipe(e) {
        if (isProcessing) return;
        const rect = canvas.getBoundingClientRect();
        swipeStart = {
          x: e.clientX - rect.left,
          y: e.clientY - rect.top,
          c: Math.floor((e.clientX - rect.left) / CELL),
          r: Math.floor((e.clientY - rect.top) / CELL),
        };
      }

      function endSwipe(e) {
        if (!swipeStart || isProcessing) return;
        const rect = canvas.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const dx = x - swipeStart.x;
        const dy = y - swipeStart.y;

        if (Math.abs(dx) > 30 || Math.abs(dy) > 30) {
          let r2 = swipeStart.r,
            c2 = swipeStart.c;
          if (Math.abs(dx) > Math.abs(dy)) c2 += dx > 0 ? 1 : -1;
          else r2 += dy > 0 ? 1 : -1;

          if (r2 >= 0 && r2 < ROWS && c2 >= 0 && c2 < COLS) {
            processTurn(swipeStart.r, swipeStart.c, r2, c2);
          }
        }
        swipeStart = null;
      }

      // --- RENDER ---
      function gameLoop() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // Draw Grid
        for (let r = 0; r < ROWS; r++) {
          for (let c = 0; c < COLS; c++) {
            const candy = grid[r][c];
            if (candy.type === -1) continue;

            const x = c * CELL + CELL / 2;
            const y = r * CELL + CELL / 2;

            ctx.save();
            ctx.font = `${CELL * 0.7}px Arial`;
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";

            // Special Effects
            if (candy.isSpecial === BOMB) {
              ctx.shadowBlur = 15;
              ctx.shadowColor = "white";
              ctx.fillText("💣", x, y);
            } else if (candy.isSpecial === STRIPE) {
              ctx.fillStyle = "rgba(255,255,255,0.3)";
              ctx.beginPath();
              ctx.arc(x, y, CELL / 2.5, 0, Math.PI * 2);
              ctx.fill();
              ctx.fillText(CANDIES[candy.type], x, y);
            } else {
              ctx.fillText(CANDIES[candy.type], x, y);
            }
            ctx.restore();
          }
        }
        requestAnimationFrame(gameLoop);
      }

      function createPop(x, y) {
        // Particle logic could go here for more "Juice"
      }

      function shake() {
        canvas.classList.add("animate-bounce");
        setTimeout(() => canvas.classList.remove("animate-bounce"), 500);
      }

      function sleep(ms) {
        return new Promise((r) => setTimeout(r, ms));
      }

      window.onload = init;
    </script>
  </body>
</html>
